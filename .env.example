APP_NAME=enterprise-wechat-rag
ENVIRONMENT=development

# PostgreSQL with pgvector, used by production adapters.
POSTGRES_DSN=postgresql://rag:rag@localhost:5432/rag
REPOSITORY_PROVIDER=memory

# MySQL help document source.
MYSQL_DSN=mysql://user:password@localhost:3306/help_center
MYSQL_HELP_DOC_TABLE=help_documents

# Model provider. Keep mock for local development and tests.
LLM_PROVIDER=mock
EMBEDDING_PROVIDER=hash
EMBEDDING_DIMENSIONS=64
LLM_API_BASE=https://api.example.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=

# RAG thresholds.
AUTO_REPLY_THRESHOLD=0.72
DRAFT_ONLY_THRESHOLD=0.50
TOP_K=5
REPLY_IMAGES_ENABLED=true
MAX_REPLY_IMAGES=3
MAX_LLM_CONTEXT_CHARS=2400
LLM_MAX_TOKENS=500
FAST_IMAGE_REPLY_ENABLED=true
FAST_IMAGE_ANSWER_CHARS=700

# WeChat adapter placeholder.
WORKTOOL_API_BASE=https://api.worktool.ymdyes.cn
WORKTOOL_ROBOT_ID=worktool1
WORKTOOL_SEND_API_TOKEN=
